###############################################################################
# env.example - copy to `terraform.tfvars` (gitignored) and apply.
#
#   Copy-Item env.example terraform.tfvars
#   terraform init
#   terraform apply -replace="aws_instance.this"
#
# This file is filled with WORKING values for this repo (real random secrets
# below). It is intended to be the seed for terraform.tfvars. Treat the
# secrets as compromised the moment this file is committed - rotate them
# (regenerate POSTGRES_PASSWORD / DJANGO_SECRET_KEY) in your real
# terraform.tfvars before going into production.
#
# If you change deploy_git_* / env_* on an EC2 that already exists, user_data
# will not re-run on the same instance. Force a recreate:
#   terraform apply -replace="aws_instance.this"
###############################################################################


# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
aws_region    = "eu-central-1"
instance_type = "t3.micro" # Free Tier (12 months). Bump to t3.small/medium for real load.
project_name  = "swarm-traefik-production"


# ---------------------------------------------------------------------------
# Network access. Tighten for production.
# ---------------------------------------------------------------------------
ssh_cidr_blocks        = ["0.0.0.0/0"] # set to ["YOUR.PUBLIC.IP/32"] in production
http_https_cidr_blocks = ["0.0.0.0/0"]
app_ports_cidr_blocks  = ["0.0.0.0/0"]


# ---------------------------------------------------------------------------
# Disk + swap. Swap is mandatory on t3.micro (1 GiB RAM).
# ---------------------------------------------------------------------------
root_volume_size_gb = 30 # Free Tier EBS allowance for 12 months
swap_size_gb        = 6


# ---------------------------------------------------------------------------
# Public IP. Elastic IP keeps the same address across instance stop/start.
# ---------------------------------------------------------------------------
associate_elastic_ip = true


# ---------------------------------------------------------------------------
# SSH key. Empty = Terraform generates a key pair and writes the private key
# to ec2_auto_key.pem (gitignored).
# ---------------------------------------------------------------------------
ssh_public_key                     = ""
ssh_generated_private_key_filename = "ec2_auto_key.pem"


# ---------------------------------------------------------------------------
# Automated deploy. user_data clones this repo, writes the four .envs files,
# builds local-only images via production-build.yml, then runs
# `docker compose -f production.yml -f compose.override.yml up -d`.
# ---------------------------------------------------------------------------
deploy_git_repo     = "https://github.com/djangoreactdev/swarm-traefik-production.git"
deploy_git_branch   = "master"
deploy_app_dir      = "/opt/swarm-app"
deploy_compose_file = "production.yml"


# ---------------------------------------------------------------------------
# Production env files written on EC2 to:
#   /opt/swarm-app/cosmetic/.envs/.production/.django
#   /opt/swarm-app/cosmetic/.envs/.production/.postgres
#   /opt/swarm-app/codehelp/.envs/.production/.django
#   /opt/swarm-app/codehelp/.envs/.production/.postgres
#
# Both .postgres files are mounted into the SAME postgres container; duplicate
# keys: codehelp wins. Container init creates DB `codehelp` + role `app`.
# scripts/ensure-postgres-databases.sh then creates DB `cosmetic` (same role).
# ---------------------------------------------------------------------------

env_cosmetic_postgres = <<-EOT
  POSTGRES_HOST=postgres
  POSTGRES_PORT=5432
  POSTGRES_DB=cosmetic
  POSTGRES_USER=app
  POSTGRES_PASSWORD=xQXvsC5XKuoob8FEyLXrrFabWalIwoe4
  EOT

env_codehelp_postgres = <<-EOT
  POSTGRES_HOST=postgres
  POSTGRES_PORT=5432
  POSTGRES_DB=codehelp
  POSTGRES_USER=app
  POSTGRES_PASSWORD=xQXvsC5XKuoob8FEyLXrrFabWalIwoe4
  EOT

