###############################################################################
# env.example - copy to `terraform.tfvars` (gitignored) and adjust as needed.
#
#   Copy-Item env.example terraform.tfvars
#   terraform init
#   terraform apply
#
# Every variable here has a working default for this repo, so an unedited copy
# is enough to bring up the full production stack on a single Free-Tier EC2.
###############################################################################


# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
aws_region    = "eu-central-1"
instance_type = "t3.micro" # Free Tier (12 months). Bump to t3.small/medium for real load.
project_name  = "swarm-traefik-production"


# ---------------------------------------------------------------------------
# Network access. Tighten for production.
# ---------------------------------------------------------------------------
ssh_cidr_blocks        = ["0.0.0.0/0"] # set to ["YOUR.PUBLIC.IP/32"] in production
http_https_cidr_blocks = ["0.0.0.0/0"]
app_ports_cidr_blocks  = ["0.0.0.0/0"]


# ---------------------------------------------------------------------------
# Disk + swap. Swap is mandatory on t3.micro (1 GiB RAM) - the full stack
# (Postgres + Redis + 2 Django stacks + 4 frontends + Traefik) will not fit
# without it. See terraform/README.md.
# ---------------------------------------------------------------------------
root_volume_size_gb = 30 # Free Tier EBS allowance for 12 months
swap_size_gb        = 6


# ---------------------------------------------------------------------------
# Public IP. Elastic IP keeps the same address across instance stop/start.
# ---------------------------------------------------------------------------
associate_elastic_ip = true


# ---------------------------------------------------------------------------
# SSH key. Leave ssh_public_key empty to let Terraform generate a key pair
# and write the private key to ec2_auto_key.pem (gitignored).
# ---------------------------------------------------------------------------
ssh_public_key                     = ""
ssh_generated_private_key_filename = "ec2_auto_key.pem"


# ---------------------------------------------------------------------------
# Automated deploy. user_data clones this repo, writes the four .envs files,
# builds the local-only images via production-build.yml, then runs
# `docker compose -f production.yml -f compose.override.yml up -d`.
# ---------------------------------------------------------------------------
deploy_git_repo     = "https://github.com/djangoreactdev/swarm-traefik-production.git"
deploy_git_branch   = "master"
deploy_app_dir      = "/opt/swarm-app"
deploy_compose_file = "production.yml"


# ---------------------------------------------------------------------------
# Production env files. If left empty, Terraform generates a minimal
# placeholder (random Postgres password + Django secret + DEBUG=False).
# That is enough for the stack to *start* on first apply; replace with your
# real production values for anything beyond a smoke test.
#
# Example (uncomment and edit):
#
# env_cosmetic_django = <<-EOT
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_SECRET_KEY=replace-me
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=cosmeticpro.pp.ua,api.cosmeticpro.pp.ua,dashboard.cosmeticpro.pp.ua
# DJANGO_ADMIN_URL=replace-me/
# REDIS_URL=redis://redis:6379/0
# DJANGO_AWS_ACCESS_KEY_ID=...
# DJANGO_AWS_SECRET_ACCESS_KEY=...
# DJANGO_AWS_STORAGE_BUCKET_NAME=...
# MAILGUN_API_KEY=...
# MAILGUN_DOMAIN=...
# SENTRY_DSN=...
# EOT
#
# env_cosmetic_postgres = <<-EOT
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=cosmetic
# POSTGRES_USER=cosmetic
# POSTGRES_PASSWORD=replace-me
# EOT
#
# env_codehelp_django = <<-EOT
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_SECRET_KEY=replace-me
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=laba.pp.ua,www.laba.pp.ua,api.laba.pp.ua,api.codehelp.pp.ua
# REDIS_URL=redis://redis:6379/1
# EOT
#
# env_codehelp_postgres = <<-EOT
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=codehelp
# POSTGRES_USER=codehelp
# POSTGRES_PASSWORD=replace-me
# EOT
